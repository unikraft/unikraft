menuconfig LIBUKRAND
	bool "ukrand: Random number generation"
	depends on HAVE_RANDOM

if LIBUKRAND

choice
	prompt "RNG Source"
	default LIBUKRAND_HW

config LIBUKRAND_HW
	bool "Hardware pass-through"
	help
	  Expose unaltered random numbers generated by the processor

config LIBUKRAND_CHACHA
	bool "ChaCha20"
	help
	  ChaCha20 is a fast CSPRNG based on Salsa20
endchoice

config LIBUKRAND_DEVFS
	bool "Register random and urandom device to devfs"
	select LIBDEVFS
	select LIBVFSCORE
endif
